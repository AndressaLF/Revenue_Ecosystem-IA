# =============================================================================
# RE-IA — modelo de .env (copie para .env e preencha — NUNCA commite .env)
# =============================================================================
# copy .env.example .env

# P0 — IA (pelo menos uma key para produce com IA)
GEMINI_API_KEY=
GROQ_API_KEY=
GROC_KEY=
CEREBRAS_KEY=
OPENROUTER_KEY=
LLM_PROVIDER_CHAIN=gemini,groq,cerebras,openrouter

# P1 — Afiliados (hoplinks)
CLICKBANK_NICKNAME=
DIGISTORE24_AFFILIATE_ID=
AMAZON_ASSOCIATE_TAG=

# P2 — Scout marketplace
DIGISTORE24_API_KEY=
DIGISTORE24_SESSION_COOKIE=
CLICKBANK_API_KEY=

# P2 — Reddit OAuth (opcional — RSS público funciona sem)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# P3 — Publicação (opcional)
MEDIUM_INTEGRATION_TOKEN=
PINTEREST_ACCESS_TOKEN=
PRODUCTHUNT_TOKEN=

# Geral
INGEST_LOCALE=en-US
INGEST_GEO=US
LOG_LEVEL=INFO
